REDIS_PASSWORD=changeme
AOF_PATH=./appendonly.aof
# AOF_FSYNC: always | everysec | no
# WARNING: 'always' fsyncs on every write and, under concurrent load, collapses
# throughput ~17x on the machine we measured (~50,000 ops/sec -> ~2,877 ops/sec,
# SET p99 22ms -> 219ms) because every mutation blocks on a synchronous fsync
# while holding the AOF lock. Only choose 'always' if per-write durability truly
# outweighs that cost. 'everysec' (the default) performed on par with no AOF.
AOF_FSYNC=everysec
AOF_REWRITE_SIZE_MB=64
DASHBOARD_PORT=8080
TLS_CERT_FILE=
TLS_KEY_FILE=
MAXMEMORY_MB=
SLOWLOG_THRESHOLD_MS=10
SENSITIVE_KEYS=
